{
  "name": "mobile-code-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A mobile-friendly coding agent you can open over the network and use from your phone to inspect, edit, and let AI write code.",
  "bin": {
    "code-agent": "./dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "cli": "tsx src/index.ts",
    "dev": "tsx src/server.ts",
    "dev:web": "vite",
    "start": "node dist/server.js",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "commander": "^14.0.0",
    "chokidar": "^4.0.3",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "fast-glob": "^3.3.3",
    "monaco-editor": "^0.54.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vite": "^7.1.10"
  }
}
